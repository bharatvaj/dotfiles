#!/bin/sh

[ $# -ne 1 ] && echo 'Usage: songdl <youtube-url>' && exit 1

: ${XDG_MUSIC_HOME:=$HOME/Music}
cd "${XDG_MUSIC_HOME:?$XDG_MUSIC_HOME not found}"

song_name="$1"

yt-dlp --extract-audio --audio-format mp3 "$song_name" --external-downloader aria2c

if type mpc >/dev/null; then
	mpc update
fi
