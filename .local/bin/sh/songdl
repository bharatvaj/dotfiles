#!/bin/sh

[ $# -ne 1 ] && echo 'Usage: songdl <youtube-url>' && exit 1

: "${XDG_MUSIC_DIR:=$HOME/Music}"
cd "${XDG_MUSIC_DIR:?$XDG_MUSIC_DIR not found}" || exit 1

song_name="$1"

(
	set -x;
	yt-dlp --extract-audio --audio-format mp3 "$song_name" --download-archive "$XDG_MUSIC_DIR/archive.txt"
)

if type mpc >/dev/null; then
	mpc update
fi
